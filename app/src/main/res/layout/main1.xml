<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Main1"
    tools:layout_editor_absoluteX="0dp"
    tools:layout_editor_absoluteY="-121dp">

    <Button
        android:id="@+id/act_vibration"
        style="@style/Widget.Material3.Button"
        android:layout_width="120sp"
        android:layout_height="120sp"
        android:layout_marginTop="36dp"
        android:text="Vibration"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="@+id/act_Zoo"
        app:layout_constraintStart_toStartOf="@+id/act_Zoo"
        app:layout_constraintTop_toBottomOf="@+id/act_Zoo" />

    <Button
        android:id="@+id/act_chiffre"
        android:layout_width="120sp"
        android:layout_height="120sp"
        android:layout_marginTop="40dp"
        android:text="Chiffre"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="@+id/act2"
        app:layout_constraintStart_toStartOf="@+id/act2"
        app:layout_constraintTop_toBottomOf="@+id/act2" />

    <Button
        android:id="@+id/act2"
        android:layout_width="120sp"
        android:layout_height="120sp"
        android:layout_marginTop="40dp"
        android:text="activity 2"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="@+id/act1"
        app:layout_constraintStart_toStartOf="@+id/act1"
        app:layout_constraintTop_toBottomOf="@+id/act1" />

    <Button
        android:id="@+id/act1"
        android:layout_width="120sp"
        android:layout_height="120sp"
        android:layout_marginStart="146dp"
        android:layout_marginTop="63dp"
        android:text="activity 1"
        android:textSize="15sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/act_Zoo"
        style="@style/Widget.Material3.Button"
        android:layout_width="120sp"
        android:layout_height="120sp"
        android:layout_marginTop="36dp"
        android:text="ZooMedia"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="@+id/act_chiffre"
        app:layout_constraintStart_toStartOf="@+id/act_chiffre"
        app:layout_constraintTop_toBottomOf="@+id/act_chiffre" />

</androidx.constraintlayout.widget.ConstraintLayout>